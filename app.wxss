page {
  min-height: 100vh;
  color: #1f2933;
  background: #fff7ec;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Segoe UI', sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}

.container {
  min-height: 100vh;
  padding-bottom: calc(176rpx + env(safe-area-inset-bottom));
}

.card {
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 48rpx rgba(242, 78, 46, 0.1);
}

.section {
  padding: 0 32rpx;
  margin-top: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title text:first-child {
  font-size: 36rpx;
  font-weight: 800;
}

.section-title text:last-child {
  color: #f24e2e;
  font-size: 24rpx;
  font-weight: 700;
}

.tags,
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag,
.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #f24e2e;
  background: #fff1e9;
  font-size: 22rpx;
  font-weight: 700;
}

.chip {
  min-height: 62rpx;
  padding: 0 24rpx;
  color: #52606d;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.06);
}

.chip.active,
.tag.active {
  color: #ffffff;
  background: #f24e2e;
}

.primary-btn {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #f24e2e, #ff8a3d);
  font-size: 30rpx;
  font-weight: 900;
}

.ghost-btn {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  color: #f24e2e;
  background: #fff1e9;
  font-size: 28rpx;
  font-weight: 900;
}

.muted {
  color: #52606d;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}
