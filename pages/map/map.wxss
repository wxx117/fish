.map-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #dff1e8;
}

.map-top {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 44rpx;
  z-index: 3;
}

.search {
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  border-radius: 40rpx;
  color: #9aa5b1;
  background: #ffffff;
  font-size: 26rpx;
  box-shadow: 0 16rpx 48rpx rgba(31, 41, 51, 0.12);
}

.filter-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.fake-map {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(255,255,255,.26) 2rpx, transparent 2rpx), linear-gradient(rgba(255,255,255,.26) 2rpx, transparent 2rpx), radial-gradient(circle at 30% 30%, #b8e0c4, transparent 24%), radial-gradient(circle at 70% 50%, #b7d7ff, transparent 26%), #dff1e8;
  background-size: 88rpx 88rpx, 88rpx 88rpx, auto, auto, auto;
}

.pin {
  position: absolute;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50% 50% 50% 16rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 48rpx rgba(31, 41, 51, 0.2);
  font-size: 44rpx;
}

.pin-red {
  left: 144rpx;
  top: 420rpx;
  color: #f24e2e;
}

.pin-green {
  left: 480rpx;
  top: 360rpx;
  color: #35b46f;
}

.pin-blue {
  left: 224rpx;
  top: 650rpx;
  color: #4aa8ff;
}

.map-card {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(176rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: 48rpx;
  background: #ffffff;
  box-shadow: 0 -16rpx 60rpx rgba(31, 41, 51, 0.12);
}

.spot-image {
  flex: 0 0 auto;
  width: 184rpx;
  height: 184rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  font-size: 56rpx;
}

.image-green {
  background: linear-gradient(135deg, rgba(53, 180, 111, 0.9), rgba(74, 168, 255, 0.58));
}

.image-orange {
  background: linear-gradient(135deg, rgba(242, 78, 46, 0.75), rgba(255, 209, 102, 0.66));
}

.image-blue {
  background: linear-gradient(135deg, rgba(74, 168, 255, 0.82), rgba(53, 180, 111, 0.5));
}

.spot-info {
  flex: 1;
}

.spot-name {
  font-size: 32rpx;
  font-weight: 900;
}

.tags {
  margin-top: 14rpx;
}

.spot-meta {
  margin-top: 14rpx;
  color: #52606d;
  font-size: 24rpx;
  line-height: 1.45;
}

.detail-btn {
  height: 68rpx;
  margin-top: 18rpx;
  padding: 0 32rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: #f24e2e;
  font-size: 26rpx;
  font-weight: 900;
}
