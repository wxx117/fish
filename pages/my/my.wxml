<view class="container my-page">
  <view class="profile-card">
    <view class="avatar">🦞</view>
    <view class="profile-info">
      <view class="nickname">{{user.nickname}}</view>
      <view class="level">{{user.level}} · {{user.points}} 积分</view>
    </view>
  </view>

  <view class="stats-card card">
    <view><text>{{user.favorites}}</text><text>收藏</text></view>
    <view><text>{{user.checkins}}</text><text>打卡</text></view>
    <view><text>{{user.posts}}</text><text>发布</text></view>
  </view>

  <view class="section">
    <view class="section-title"><text>我的虾友中心</text><text>等级规则</text></view>
    <view class="menu-card card">
      <view wx:for="{{menu}}" wx:key="label" class="menu-item" bindtap="showTodo">
        <text>{{item.label}}</text>
        <text>{{item.value}} 〉</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="badge-card">
      <view class="badge-title">本周任务</view>
      <view class="badge-desc">发布 1 条真实打卡，可获得 10 积分并点亮“周末虾友”徽章。</view>
    </view>
  </view>
</view>
