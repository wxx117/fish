.form-page {
  padding: 64rpx 32rpx;
  background: #fff7ec;
}

.page-header {
  margin-bottom: 36rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 900;
}

.desc {
  margin-top: 14rpx;
  color: #52606d;
  font-size: 28rpx;
  line-height: 1.55;
}

.form-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.label {
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.no-margin {
  margin-bottom: 0;
}

.input,
.textarea {
  width: 100%;
  padding: 0 24rpx;
  border-radius: 28rpx;
  color: #1f2933;
  background: #f6f8fa;
  font-size: 28rpx;
}

.input {
  height: 84rpx;
}

.textarea {
  height: 180rpx;
  padding-top: 22rpx;
  line-height: 1.55;
}

.location-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.helper {
  margin-top: 10rpx;
  color: #52606d;
  font-size: 24rpx;
}

.location-icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  background: #fff1e9;
  font-size: 48rpx;
}

.upload-box {
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 24rpx 0;
  border: 4rpx dashed #ffc4ad;
  border-radius: 40rpx;
  color: #f24e2e;
  background: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
}

.submit {
  width: 100%;
}
